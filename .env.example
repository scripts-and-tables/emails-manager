# Django
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Database (leave unset locally to fall back to SQLite)
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# Fernet key for encrypting IMAP passwords at rest.
# Generate once with:  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=

# Resend (outbound transactional email). Get key at https://resend.com/api-keys
# RESEND_FROM_EMAIL accepts RFC 5322 format: "Display Name <addr@your-verified-domain>"
RESEND_API_KEY=
RESEND_FROM_EMAIL=Mails Manager App <noreply-em@yourdomain.com>
